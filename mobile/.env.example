# AgriConto Pro Mobile — Environment
# Copy to .env and set your backend URL.

# Backend API URL - point to your AgriConto Pro backend instance.
# For Android emulator use 10.0.2.2 (maps to host localhost).
# If the backend runs locally on port 8001, keep this default:
EXPO_PUBLIC_API_URL=http://10.0.2.2:8001

# For a physical Android phone, use the PC LAN IP and the backend port:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8001
