{
  "name": "agriconto-pro",
  "version": "0.1.1",
  "description": "Italian agricultural accounting and farm management platform",
  "author": "AgriConto Pro",
  "homepage": "https://agriconto.local",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "electron .",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "desktop:pack": "npm run build && electron-builder --linux deb AppImage",
    "desktop:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.agriconto.pro",
    "productName": "AgriConto Pro",
    "copyright": "Copyright © 2026 AgriConto Pro",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icons/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "app/**/*",
          "alembic/**/*",
          "scripts/**/*",
          "pyproject.toml",
          "alembic.ini",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/.ruff_cache/**",
          "!storage/**",
          "!.env",
          "!.env.*",
          "!agriconto_pro_backend.egg-info/**"
        ]
      }
    ],
    "linux": {
      "executableName": "agriconto-pro",
      "artifactName": "agriconto-pro-${version}-${arch}.${ext}",
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Office",
      "icon": "build/icons",
      "maintainer": "AgriConto Pro",
      "synopsis": "Italian agricultural accounting and farm management platform",
      "description": "AgriConto Pro organizes farm accounting, workers, crops, documents and accountant-ready reports."
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnss3",
        "libxss1",
        "libxtst6"
      ]
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.6",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.18",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.10"
  }
}
