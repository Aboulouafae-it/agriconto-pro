{
  "name": "agriconto-pro",
  "version": "0.1.0",
  "private": true,
  "description": "AgriConto Pro monorepo developer commands",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "dev": "docker compose up --build",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:desktop": "npm --prefix frontend run desktop:dev",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:docker": "docker compose up --build",
    "health:backend": "curl -f http://localhost:8000/health",
    "test": "cd backend && pytest app/tests",
    "lint": "cd backend && ruff check app scripts",
    "seed": "cd backend && python scripts/seed_demo.py",
    "migrate": "cd backend && alembic upgrade head",
    "desktop:dir": "npm --prefix frontend run desktop:dir",
    "desktop:pack": "npm --prefix frontend run desktop:pack"
  },
  "engines": {
    "node": ">=20"
  }
}
